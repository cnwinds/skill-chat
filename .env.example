NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173
DATA_ROOT=./data
SKILLS_ROOT=./skills
SESSION_EXPIRES_IN=7d
# WEB_ORIGIN must exactly match the browser-facing frontend origin.
# OpenAI / Assistant Tools runtime config stays in system settings.
ENABLE_REASONING_EVENTS=false
IMAGE_THUMBNAIL_THRESHOLD_BYTES=262144
IMAGE_THUMBNAIL_MAX_WIDTH=640
IMAGE_THUMBNAIL_MAX_HEIGHT=640
IMAGE_THUMBNAIL_QUALITY=78
LLM_REQUEST_TIMEOUT_MS=45000
MAX_CONCURRENT_RUNS=5
RUN_TIMEOUT_MS=120000
