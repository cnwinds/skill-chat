NODE_ENV=production
PORT=3000
WEB_PORT=7070
WEB_ORIGIN=http://localhost:7070
DATA_ROOT=/app/data
SKILLS_ROOT=/app/skills
SESSION_EXPIRES_IN=7d
# WEB_ORIGIN must match the final external browser origin, for example https://app.example.com.
# OpenAI / Assistant Tools runtime config stays in system settings.
ENABLE_REASONING_EVENTS=false
LLM_REQUEST_TIMEOUT_MS=45000
MAX_CONCURRENT_RUNS=5
RUN_TIMEOUT_MS=120000
